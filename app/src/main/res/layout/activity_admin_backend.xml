<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/spacing_20dp"
        android:paddingTop="@dimen/spacing_16dp"
        android:paddingBottom="@dimen/spacing_32dp">

        <!-- Back / title row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/admin_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← 返回"
                style="@style/Widget.CalMobile.BackButton" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/admin_backend_title"
                android:textAppearance="@style/TextAppearance.Title" />

            <!-- Spacer to balance the back button -->
            <View
                android:layout_width="@dimen/spacing_56dp"
                android:layout_height="@dimen/spacing_1dp" />
        </LinearLayout>

        <!-- Tab switcher row -->
        <LinearLayout
            android:id="@+id/admin_tab_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_16dp"
            android:background="@drawable/bg_surface_variant"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_4dp" />

        <!-- System summary bar -->
        <LinearLayout
            android:id="@+id/admin_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_12dp"
            android:background="@drawable/bg_card"
            android:elevation="@dimen/elevation_low"
            android:orientation="vertical"
            android:padding="@dimen/spacing_14dp" />

        <!-- Users section -->
        <LinearLayout
            android:id="@+id/admin_users_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_16dp"
            android:orientation="vertical" />

        <!-- User detail panel (hidden by default) -->
        <LinearLayout
            android:id="@+id/admin_user_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_12dp"
            android:background="@drawable/bg_card"
            android:elevation="@dimen/elevation_low"
            android:orientation="vertical"
            android:padding="@dimen/spacing_16dp"
            android:visibility="gone" />

        <!-- Exhibitions section -->
        <LinearLayout
            android:id="@+id/admin_exhibitions_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_16dp"
            android:orientation="vertical" />

        <!-- Exhibition detail panel (hidden by default) -->
        <LinearLayout
            android:id="@+id/admin_exhibition_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_12dp"
            android:background="@drawable/bg_card"
            android:elevation="@dimen/elevation_low"
            android:orientation="vertical"
            android:padding="@dimen/spacing_16dp"
            android:visibility="gone" />

        <!-- Settings section -->
        <LinearLayout
            android:id="@+id/admin_settings_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_16dp"
            android:orientation="vertical" />

    </LinearLayout>
</ScrollView>
