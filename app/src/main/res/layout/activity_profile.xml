<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/spacing_20dp"
        android:paddingTop="@dimen/spacing_16dp"
        android:paddingBottom="@dimen/spacing_32dp">

        <!-- Back / title row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/profile_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← 返回"
                style="@style/Widget.CalMobile.BackButton" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/profile_title"
                android:textAppearance="@style/TextAppearance.Title" />

            <!-- Spacer to balance the back button -->
            <View
                android:layout_width="@dimen/spacing_56dp"
                android:layout_height="@dimen/spacing_1dp" />
        </LinearLayout>

        <!-- Header section (avatar + nickname) built programmatically -->
        <LinearLayout
            android:id="@+id/profile_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_20dp"
            android:background="@drawable/bg_card"
            android:elevation="@dimen/elevation_low"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="@dimen/spacing_24dp" />

        <!-- Display info section built programmatically -->
        <LinearLayout
            android:id="@+id/profile_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_12dp"
            android:background="@drawable/bg_card"
            android:elevation="@dimen/elevation_low"
            android:orientation="vertical"
            android:padding="@dimen/spacing_16dp" />

        <!-- Edit fields section (hidden by default) built programmatically -->
        <LinearLayout
            android:id="@+id/profile_edit_fields"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_12dp"
            android:background="@drawable/bg_card"
            android:elevation="@dimen/elevation_low"
            android:orientation="vertical"
            android:padding="@dimen/spacing_16dp"
            android:visibility="gone" />

        <!-- Action buttons area -->
        <LinearLayout
            android:id="@+id/profile_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_12dp"
            android:orientation="horizontal" />

        <!-- Notification settings section built programmatically -->
        <LinearLayout
            android:id="@+id/profile_notification_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_16dp"
            android:background="@drawable/bg_card"
            android:elevation="@dimen/elevation_low"
            android:orientation="vertical"
            android:padding="@dimen/spacing_16dp" />

        <!-- Notification history section built programmatically -->
        <LinearLayout
            android:id="@+id/profile_notification_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_12dp"
            android:background="@drawable/bg_card"
            android:elevation="@dimen/elevation_low"
            android:orientation="vertical"
            android:padding="@dimen/spacing_16dp" />

    </LinearLayout>
</ScrollView>
