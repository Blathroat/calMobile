<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/spacing_16dp"
    android:paddingTop="@dimen/spacing_16dp">

    <!-- Back button row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <Button
            android:id="@+id/search_back_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← 返回"
            style="@style/Widget.CalMobile.BackButton" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/search_title"
            android:textAppearance="@style/TextAppearance.Title" />

        <!-- Spacer for symmetry -->
        <View
            android:layout_width="@dimen/spacing_56dp"
            android:layout_height="@dimen/spacing_1dp" />
    </LinearLayout>

    <!-- Search input card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_16dp"
        android:background="@drawable/bg_card"
        android:elevation="@dimen/elevation_low"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_8dp">

        <EditText
            android:id="@+id/search_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/search_hint"
            android:inputType="text"
            android:maxLines="1"
            android:singleLine="true"
            android:background="@android:color/transparent"
            android:paddingHorizontal="@dimen/spacing_12dp"
            android:paddingVertical="@dimen/spacing_10dp"
            android:textSize="15sp"
            android:textColorHint="@color/text_hint" />

        <Button
            android:id="@+id/search_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/search_btn"
            style="@style/Widget.CalMobile.Button.Primary" />
    </LinearLayout>

    <!-- Search history section -->
    <LinearLayout
        android:id="@+id/search_history_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_16dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/search_history_title"
                android:textAppearance="@style/TextAppearance.Label" />

            <Button
                android:id="@+id/search_clear_history_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/search_clear_history"
                android:textSize="12sp"
                style="@style/Widget.CalMobile.Button.Text" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/search_history_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_8dp"
            android:orientation="horizontal" />
    </LinearLayout>

    <!-- Results count -->
    <TextView
        android:id="@+id/search_results_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_12dp"
        android:textAppearance="@style/TextAppearance.BodySmall"
        android:visibility="gone" />

    <!-- Scrollable results -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="@dimen/spacing_8dp"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/search_results_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/spacing_16dp" />
    </ScrollView>

</LinearLayout>
