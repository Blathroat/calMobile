<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/spacing_20dp"
        android:paddingTop="@dimen/spacing_24dp"
        android:paddingBottom="@dimen/spacing_32dp">

        <!-- Header section -->
        <TextView
            android:id="@+id/title_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textAppearance="@style/TextAppearance.Headline" />

        <TextView
            android:id="@+id/status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_4dp"
            android:textAppearance="@style/TextAppearance.Subtitle" />

        <!-- Calendar section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_28dp"
            android:background="@drawable/bg_card"
            android:elevation="@dimen/elevation_low"
            android:orientation="vertical"
            android:padding="@dimen/spacing_16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/month_view_title"
                android:textAppearance="@style/TextAppearance.Title" />

            <GridLayout
                android:id="@+id/calendar_grid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_12dp"
                android:alignmentMode="alignMargins"
                android:columnCount="7"
                android:rowCount="5"
                android:useDefaultMargins="false" />
        </LinearLayout>

        <!-- Today's exhibitions section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_28dp"
            android:text="@string/today_exhibitions"
            android:textAppearance="@style/TextAppearance.Title" />

        <LinearLayout
            android:id="@+id/exhibition_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_8dp"
            android:orientation="vertical" />

        <!-- Detail panel -->
        <LinearLayout
            android:id="@+id/detail_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_20dp"
            android:background="@drawable/bg_card"
            android:elevation="@dimen/elevation_low"
            android:orientation="vertical"
            android:padding="@dimen/spacing_16dp" />

        <!-- Registration panel -->
        <LinearLayout
            android:id="@+id/registration_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_20dp"
            android:background="@drawable/bg_card"
            android:elevation="@dimen/elevation_low"
            android:orientation="vertical"
            android:padding="@dimen/spacing_16dp"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/registration_answers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

        <!-- My registrations section -->
        <TextView
            android:id="@+id/my_registrations_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_28dp"
            android:text="@string/my_registrations_title"
            android:textAppearance="@style/TextAppearance.Title" />

        <LinearLayout
            android:id="@+id/my_registrations_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_8dp"
            android:orientation="vertical" />

        <!-- Navigation buttons -->
        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/spacing_1dp"
            android:layout_marginTop="@dimen/spacing_28dp"
            android:background="@color/divider_color" />

        <Button
            android:id="@+id/go_to_profile_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_16dp"
            android:text="@string/go_to_profile"
            style="@style/Widget.CalMobile.Button.Secondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/go_to_exhibitor_backend_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_4dp"
                android:text="@string/go_to_exhibitor_backend"
                style="@style/Widget.CalMobile.Button.Secondary" />

            <Button
                android:id="@+id/go_to_admin_backend_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_4dp"
                android:text="@string/go_to_admin_backend"
                style="@style/Widget.CalMobile.Button.Secondary" />
        </LinearLayout>

        <Button
            android:id="@+id/go_to_search_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_8dp"
            android:text="@string/go_to_search"
            style="@style/Widget.CalMobile.Button.Secondary" />

        <Button
            android:id="@+id/logout_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_20dp"
            android:text="@string/auth_logout"
            style="@style/Widget.CalMobile.Button.Danger" />

    </LinearLayout>
</ScrollView>
