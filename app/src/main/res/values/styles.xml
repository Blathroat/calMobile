<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ═══════════════════════════════════════════════════════════════
         Text Appearances — Consistent typography scale
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Display: Large screen titles -->
    <style name="TextAppearance.Headline" parent="">
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:lineSpacingMultiplier">1.15</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <!-- Title: Section headers -->
    <style name="TextAppearance.Title" parent="">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:lineSpacingMultiplier">1.2</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <!-- Title Medium: Sub-section headers -->
    <style name="TextAppearance.TitleMedium" parent="">
        <item name="android:textSize">17sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:lineSpacingMultiplier">1.25</item>
    </style>

    <!-- Body: Primary content text -->
    <style name="TextAppearance.Body" parent="">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>

    <!-- Body Small: Secondary content -->
    <style name="TextAppearance.BodySmall" parent="">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:lineSpacingMultiplier">1.35</item>
    </style>

    <!-- Label: Field labels, captions -->
    <style name="TextAppearance.Label" parent="">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <!-- Caption: Small helper text -->
    <style name="TextAppearance.Caption" parent="">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:lineSpacingMultiplier">1.3</item>
    </style>

    <!-- Subtitle: Under headline -->
    <style name="TextAppearance.Subtitle" parent="">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:lineSpacingMultiplier">1.35</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════
         Button Styles
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Primary button: Teal filled, white text -->
    <style name="Widget.CalMobile.Button.Primary" parent="android:Widget.Button">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@color/button_primary_text</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingLeft">@dimen/spacing_20dp</item>
        <item name="android:paddingRight">@dimen/spacing_20dp</item>
        <item name="android:paddingTop">@dimen/spacing_12dp</item>
        <item name="android:paddingBottom">@dimen/spacing_12dp</item>
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:elevation">@dimen/elevation_low</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Secondary button: Light gray filled, dark text -->
    <style name="Widget.CalMobile.Button.Secondary" parent="android:Widget.Button">
        <item name="android:background">@drawable/bg_button_secondary</item>
        <item name="android:textColor">@color/button_secondary_text</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingLeft">@dimen/spacing_20dp</item>
        <item name="android:paddingRight">@dimen/spacing_20dp</item>
        <item name="android:paddingTop">@dimen/spacing_12dp</item>
        <item name="android:paddingBottom">@dimen/spacing_12dp</item>
        <item name="android:minHeight">@dimen/button_height</item>
    </style>

    <!-- Text button: Transparent, teal text -->
    <style name="Widget.CalMobile.Button.Text" parent="android:Widget.Button">
        <item name="android:background">@drawable/bg_button_text</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingLeft">@dimen/spacing_16dp</item>
        <item name="android:paddingRight">@dimen/spacing_16dp</item>
        <item name="android:paddingTop">@dimen/spacing_10dp</item>
        <item name="android:paddingBottom">@dimen/spacing_10dp</item>
    </style>

    <!-- Danger button: Red tinted -->
    <style name="Widget.CalMobile.Button.Danger" parent="android:Widget.Button">
        <item name="android:background">@drawable/bg_button_danger</item>
        <item name="android:textColor">@color/button_danger_text</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingLeft">@dimen/spacing_20dp</item>
        <item name="android:paddingRight">@dimen/spacing_20dp</item>
        <item name="android:paddingTop">@dimen/spacing_12dp</item>
        <item name="android:paddingBottom">@dimen/spacing_12dp</item>
        <item name="android:minHeight">@dimen/button_height</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════
         Input Field Styles
         ═══════════════════════════════════════════════════════════════ -->

    <style name="Widget.CalMobile.EditText" parent="android:Widget.EditText">
        <item name="android:background">@drawable/bg_input_field</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="android:textSize">15sp</item>
        <item name="android:paddingLeft">@dimen/spacing_14dp</item>
        <item name="android:paddingRight">@dimen/spacing_14dp</item>
        <item name="android:paddingTop">@dimen/spacing_14dp</item>
        <item name="android:paddingBottom">@dimen/spacing_14dp</item>
        <item name="android:minHeight">@dimen/input_height</item>
        <item name="android:lineSpacingMultiplier">1.3</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════
         Card Style
         ═══════════════════════════════════════════════════════════════ -->

    <style name="Widget.CalMobile.Card" parent="">
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:padding">@dimen/spacing_16dp</item>
        <item name="android:elevation">@dimen/elevation_low</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════
         Tab Button Style
         ═══════════════════════════════════════════════════════════════ -->

    <style name="Widget.CalMobile.Tab" parent="android:Widget.Button">
        <item name="android:background">@drawable/bg_tab_inactive</item>
        <item name="android:textColor">@color/tab_inactive_text</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingLeft">@dimen/spacing_12dp</item>
        <item name="android:paddingRight">@dimen/spacing_12dp</item>
        <item name="android:paddingTop">@dimen/spacing_10dp</item>
        <item name="android:paddingBottom">@dimen/spacing_10dp</item>
        <item name="android:minHeight">@dimen/button_height_small</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════
         Chip Style (search history)
         ═══════════════════════════════════════════════════════════════ -->

    <style name="Widget.CalMobile.Chip" parent="android:Widget.Button">
        <item name="android:background">@drawable/bg_chip</item>
        <item name="android:textColor">@color/chip_text</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingLeft">@dimen/spacing_14dp</item>
        <item name="android:paddingRight">@dimen/spacing_14dp</item>
        <item name="android:paddingTop">@dimen/spacing_6dp</item>
        <item name="android:paddingBottom">@dimen/spacing_6dp</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════
         Back Button Style
         ═══════════════════════════════════════════════════════════════ -->

    <style name="Widget.CalMobile.BackButton" parent="">
        <item name="android:background">@drawable/bg_back_button</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:paddingLeft">@dimen/spacing_14dp</item>
        <item name="android:paddingRight">@dimen/spacing_14dp</item>
        <item name="android:paddingTop">@dimen/spacing_8dp</item>
        <item name="android:paddingBottom">@dimen/spacing_8dp</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════
         Status Badge Styles
         ═══════════════════════════════════════════════════════════════ -->

    <style name="Widget.CalMobile.StatusBadge" parent="">
        <item name="android:background">@drawable/bg_status_badge</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingLeft">@dimen/spacing_10dp</item>
        <item name="android:paddingRight">@dimen/spacing_10dp</item>
        <item name="android:paddingTop">@dimen/spacing_4dp</item>
        <item name="android:paddingBottom">@dimen/spacing_4dp</item>
    </style>
</resources>
